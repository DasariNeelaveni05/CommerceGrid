# CommerceGrid — copy to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB Connection (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/commercegrid
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/commercegrid

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Cloudinary (same creds as Velora)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS — frontend URL
CLIENT_URL=http://localhost:5173
